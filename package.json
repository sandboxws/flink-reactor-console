{
  "name": "flink-reactor-console",
  "version": "0.1.0",
  "private": true,
  "description": "FlinkReactor Console — Dashboard + Server",
  "packageManager": "pnpm@10.30.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandboxws/flink-reactor-console.git"
  },
  "scripts": {
    "dev": "pnpm --filter dashboard dev",
    "dev:live": "FLINK_REST_URL=http://localhost:8081 pnpm --filter dashboard dev",
    "build": "pnpm --filter @flink-reactor/ui build && pnpm --filter dashboard build",
    "test": "pnpm --filter dashboard test",
    "typecheck": "pnpm --filter dashboard typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "ui:embed": "pnpm --filter @flink-reactor/ui-embeddings embed",
    "ui:search": "pnpm --filter @flink-reactor/ui-embeddings search",
    "ui:benchmark": "pnpm --filter @flink-reactor/ui-embeddings benchmark",
    "generate:completions": "npx tsx tools/generate-dsl-completions.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@changesets/cli": "^2.30.0"
  }
}
