{
  "name": "@flink-reactor/ui",
  "version": "0.1.0",
  "description": "Design system components for FlinkReactor applications",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandboxws/flink-reactor.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/sandboxws/flink-reactor/issues"
  },
  "homepage": "https://github.com/sandboxws/flink-reactor/tree/main/packages/ui#readme",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./fixtures": {
      "import": {
        "types": "./dist/fixtures/index.d.ts",
        "default": "./dist/fixtures/index.js"
      }
    },
    "./styles": "./src/styles/index.css",
    "./styles/tokens": "./src/styles/tokens.css",
    "./styles/components": "./src/styles/components.css",
    "./src/*": "./src/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "recharts": "^2.0.0",
    "date-fns": "^3.0.0 || ^4.0.0",
    "@tanstack/react-virtual": "^3.0.0",
    "@xyflow/react": "^12.0.0",
    "react-icons": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "recharts": { "optional": true },
    "date-fns": { "optional": true },
    "@tanstack/react-virtual": { "optional": true },
    "@xyflow/react": { "optional": true },
    "react-icons": { "optional": true }
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.563.0",
    "react-resizable-panels": "^4.7.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tanstack/react-virtual": "^3.13.22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/recharts": "^2.0.1",
    "@xyflow/react": "^12.6.0",
    "date-fns": "^4.1.0",
    "react-icons": "^5.5.0",
    "recharts": "^2.15.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
