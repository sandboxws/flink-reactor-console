# ─── Core ────────────────────────────────────────────
DASHBOARD_PORT=3001                       # Dashboard server port

# ─── Display ─────────────────────────────────────────
CLUSTER_DISPLAY_NAME=Default Cluster
NEXT_PUBLIC_THEME=dark                    # dark | light
NEXT_PUBLIC_ACCENT_COLOR=#d97085          # Primary accent color

# ─── GraphQL Backend ─────────────────────────────────
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8080/graphql  # Go backend GraphQL endpoint (dev only, production uses relative /graphql)
