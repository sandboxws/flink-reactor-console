# ─── Core ────────────────────────────────────────────
FLINK_REST_URL=http://localhost:8081     # Flink cluster REST API URL
DASHBOARD_PORT=3001                       # Dashboard server port

# ─── Authentication ──────────────────────────────────
FLINK_AUTH_TYPE=none                      # none | basic | token
FLINK_AUTH_USERNAME=                      # Required when auth_type=basic
FLINK_AUTH_PASSWORD=                      # Required when auth_type=basic
FLINK_AUTH_TOKEN=                         # Required when auth_type=token

# ─── SSL/TLS ────────────────────────────────────────
FLINK_SSL_ENABLED=false
FLINK_SSL_CA_PATH=                        # Path to CA certificate file

# ─── Behavior ────────────────────────────────────────
DASHBOARD_POLL_INTERVAL=5000              # Polling interval in ms
DASHBOARD_LOG_BUFFER_SIZE=100000          # Max log entries in memory

# ─── Display ─────────────────────────────────────────
CLUSTER_DISPLAY_NAME=Default Cluster
NEXT_PUBLIC_THEME=dark                    # dark | light
NEXT_PUBLIC_ACCENT_COLOR=#d97085          # Primary accent color

# ─── Multi-Cluster (JSON array, overrides FLINK_REST_URL) ─
# FLINK_CLUSTERS=[{"name":"prod","url":"https://flink-prod:8081","default":true},{"name":"staging","url":"https://flink-staging:8081"}]

# ─── RBAC ────────────────────────────────────────────
DASHBOARD_RBAC_ENABLED=false
# DASHBOARD_RBAC_PROVIDER=basic           # basic | oidc
# DASHBOARD_RBAC_ROLES={"admin":["*"],"viewer":["read"]}

# ─── Prometheus ──────────────────────────────────────
PROMETHEUS_ENABLED=false
# PROMETHEUS_URL=http://localhost:9090

# ─── Alerts ──────────────────────────────────────────
ALERT_WEBHOOK_ENABLED=false
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Development ─────────────────────────────────────
DASHBOARD_MOCK_MODE=auto                  # auto | on | off
# auto = mock when FLINK_REST_URL is not set
