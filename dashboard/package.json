{
  "name": "@flink-reactor/dashboard",
  "version": "0.1.0",
  "description": "Real-time monitoring dashboard for Apache Flink clusters",
  "type": "module",
  "private": false,
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandboxws/flink-reactor-console.git",
    "directory": "dashboard"
  },
  "bugs": {
    "url": "https://github.com/sandboxws/flink-reactor-console/issues"
  },
  "homepage": "https://github.com/sandboxws/flink-reactor-console#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "public",
    ".env.example"
  ],
  "scripts": {
    "build": "vite build",
    "build:static": "vite build && cp -r dist/ ../server/dashboard/",
    "dev": "vite --port 3001",
    "preview": "vite preview --port 3001",
    "lint": "biome check",
    "format": "biome format --write",
    "graphql:codegen": "graphql-codegen --config codegen.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@flink-reactor/dsl": "0.1.8-rc.3",
    "@flink-reactor/instruments-ui": "workspace:*",
    "@flink-reactor/ui": "workspace:*",
    "@lezer/highlight": "^1.2.3",
    "@shikijs/core": "^4.0.2",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@tanstack/react-router": "^1.167.3",
    "@tanstack/react-virtual": "^3.13.22",
    "@urql/core": "^6.0.1",
    "@xyflow/react": "^12.10.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "date-fns": "^4.1.0",
    "graphql": "^16.13.1",
    "lucide-react": "^0.563.0",
    "motion": "^12.36.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.7.3",
    "recharts": "^2.15.4",
    "shiki": "^4.0.2",
    "sucrase": "^3.35.1",
    "tailwind-merge": "^3.5.0",
    "tslog": "^4.10.2",
    "urql": "^5.0.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/typescript-operations": "^4.6.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-plugin": "^1.166.12",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "smol-toml": "^1.6.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
