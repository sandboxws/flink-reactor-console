{
  "name": "@flink-reactor/dashboard",
  "version": "0.1.0",
  "description": "Real-time monitoring dashboard for Apache Flink clusters",
  "type": "module",
  "private": false,
  "license": "MIT",
  "bin": {
    "flink-reactor-dashboard": "./dist/cli.js"
  },
  "files": [
    ".next/standalone",
    ".next/static",
    "public",
    "dist",
    ".env.example"
  ],
  "scripts": {
    "build": "next build",
    "build:cli": "tsup",
    "build:package": "pnpm build && pnpm build:cli && node scripts/prepare-standalone.js",
    "dev": "next dev --port 3001",
    "start": "next start",
    "prepublishOnly": "pnpm build:package",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.9",
    "@xyflow/react": "^12.10.0",
    "commander": "^13.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.0",
    "geist": "^1.5.1",
    "lucide-react": "^0.563.0",
    "motion": "^12.31.0",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "recharts": "^2.15.4",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3"
  }
}
