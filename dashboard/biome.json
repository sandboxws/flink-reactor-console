{
  "$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
  "extends": "//",
  "files": {
    "includes": ["**", "!src/routeTree.gen.ts"]
  },
  "linter": {
    "domains": { "react": "recommended" },
    "rules": {
      "suspicious": {
        "noExplicitAny": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/routes/**/*.tsx", "vite.config.ts"],
      "linter": { "rules": { "style": { "noDefaultExport": "off" } } }
    }
  ]
}
