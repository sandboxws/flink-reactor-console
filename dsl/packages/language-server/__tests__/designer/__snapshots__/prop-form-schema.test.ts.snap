      "name": "on",
      "readOnlyInForm": false,
      "required": true,
      "type": "string",
    },
    {
      "help": "Right input stream (construct node)",
      "inputKind": "object",
      "name": "right",
      "readOnlyInForm": true,
      "required": true,
      "type": "ConstructNode",
    },
    {
      "help": "Query hints for join optimization",
      "inputKind": "object",
      "name": "hints",
      "readOnlyInForm": true,
      "required": false,
      "type": "JoinHints",
    },
    {
      "inputKind": "number",
      "name": "parallelism",
      "readOnlyInForm": false,
      "required": false,
      "type": "number",
    },
    {
      "help": "State TTL for join state expiry (e.g. '1h', '30min')",
      "inputKind": "string",
      "name": "stateTtl",
      "readOnlyInForm": false,
      "required": false,
      "type": "string",
    },
    {
      "help": "Enable operator tailing for this join",
      "inputKind": "object",
      "name": "tap",
      "readOnlyInForm": true,
      "required": false,
      "type": "boolean | TapConfig",
    },
    {
      "help": "Join type (default: 'inner')",
      "inputKind": "enum",
      "name": "type",
      "options": [
        "inner",
        "left",
        "right",
        "full",
        "anti",
        "semi",
      ],
      "readOnlyInForm": false,
      "required": false,
      "type": "JoinType",
    },
  ],
  "runtimeRequired": [],
}
`;

exports[`prop-form schema projection > snapshots the representative components (KafkaSource, Filter, IcebergSink, Join) > KafkaSource 1`] = `
{
  "component": "KafkaSource",
  "fields": [
    {
      "inputKind": "object",
      "name": "schema",
      "readOnlyInForm": true,
      "required": true,
      "type": "SchemaDefinition<T>",
    },
    {
      "inputKind": "string",
      "name": "topic",
      "readOnlyInForm": false,
      "required": true,
      "type": "string",
    },
    {
      "inputKind": "string",
      "name": "bootstrapServers",
      "readOnlyInForm": false,
      "required": false,
      "type": "string",
    },
    {
      "inputKind": "string",
      "name": "consumerGroup",
      "readOnlyInForm": false,
      "required": false,
      "type": "string",
    },
    {
      "inputKind": "enum",
      "name": "format",
      "options": [
        "csv",
        "json",
        "avro",
        "debezium-json",
        "debezium-avro",
        "debezium-protobuf",
        "canal-json",
        "maxwell-json",
      ],
      "readOnlyInForm": false,
      "required": false,
      "type": "KafkaFormat",
    },
    {
      "help": "Optional SQL table name. Defaults to topic name normalized as a SQL identifier.",
      "inputKind": "string",
      "name": "name",
      "readOnlyInForm": false,
      "required": false,
      "type": "string",
    },
    {
      "inputKind": "number",
      "name": "parallelism",
      "readOnlyInForm": false,
      "required": false,
      "type": "number",
    },
    {
      "inputKind": "array",
      "name": "primaryKey",
      "readOnlyInForm": false,
      "required": false,
      "type": "readonly string[]",
    },
    {
      "help": "Confluent Schema Registry URL. Required when \`format\` is \`"debezium-avro"\`
or \`"debezium-protobuf"\` — the Flink deserializer fetches the writer schema
from this endpoint at runtime. The deployment template must expose a
reachable Schema Registry (in-cluster sidecar or external endpoint); see
the Confluent \`flink-sql-avro-confluent-registry\` /
\`flink-sql-protobuf-confluent-registry\` format docs for the request shape.",
      "inputKind": "string",
      "name": "schemaRegistryUrl",
      "readOnlyInForm": false,
      "required": false,
      "type": "string",
    },
    {
      "inputKind": "enum",
      "name": "startupMode",
      "options": [
        "latest-offset",
        "earliest-offset",
        "group-offsets",
        "timestamp",
      ],
      "readOnlyInForm": false,
      "required": false,
      "type": "KafkaStartupMode",
    },
    {
      "help": "Enable operator tailing for this source",
      "inputKind": "object",
      "name": "tap",
      "readOnlyInForm": true,
      "required": false,
      "type": "boolean | TapConfig",
    },
    {
      "inputKind": "object",
      "name": "watermark",
      "readOnlyInForm": true,
      "required": false,
      "type": "WatermarkDeclaration",
    },
  ],
  "runtimeRequired": [
    "topic",
    "schema",
  ],
}
`;
