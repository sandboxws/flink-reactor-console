{
  "name": "@flink-reactor/language-server",
  "version": "0.1.0",
  "description": "Language Server Protocol backend for FlinkReactor — synthesis-backed validation, completions, hover, code actions, and source-position mapping for any LSP client",
  "type": "module",
  "license": "BSL-1.1",
  "author": "Ahmed El.Hussaini <328866+sandboxws@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandboxws/flink-reactor-dsl.git",
    "directory": "packages/language-server"
  },
  "bugs": {
    "url": "https://github.com/sandboxws/flink-reactor-dsl/issues"
  },
  "homepage": "https://github.com/sandboxws/flink-reactor-dsl/tree/main/packages/language-server#readme",
  "keywords": [
    "flink",
    "flink-reactor",
    "lsp",
    "language-server",
    "vscode",
    "intellij",
    "neovim"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "bin": {
    "flink-reactor-lsp": "./bin/flink-reactor-lsp.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gen:prop-metadata": "tsx scripts/generate-prop-metadata.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@flink-reactor/dsl": "workspace:*",
    "@flink-reactor/ts-plugin": "workspace:*",
    "jiti": "^2.6.1",
    "typescript": "^5.7.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsup": "^8.4.0",
    "vitest": "^3.0.0"
  }
}
