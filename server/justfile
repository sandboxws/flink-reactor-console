# reactor-server task runner

# Build the server binary
build:
    go build -o bin/reactor-server ./cmd/reactor-server/

# Run all tests
test:
    go test ./...

# Run linter
lint:
    golangci-lint run

# Run gqlgen code generation
generate:
    go generate ./...

# Run the server in development mode
dev:
    go run ./cmd/reactor-server/

# Build Docker image (builds dashboard, copies static assets, then builds image)
docker:
    cd .. && pnpm build
    mkdir -p dashboard
    rsync -a --delete ../dashboard/dist/ dashboard/
    docker build \
        --build-context instruments=../../flink-reactor-instruments/server \
        -t reactor-server .

# Build Docker image inside minikube's Docker daemon
docker-minikube:
    cd .. && pnpm build
    mkdir -p dashboard
    rsync -a --delete ../dashboard/dist/ dashboard/
    eval $(minikube docker-env) && docker build \
        --build-context instruments=../../flink-reactor-instruments/server \
        -t reactor-server .

# Run tests with coverage
coverage:
    go test -coverprofile=coverage.out ./...
    go tool cover -html=coverage.out -o coverage.html

# Format code
fmt:
    gofumpt -w .

# Run full CI pipeline (build + lint + test)
ci: build lint test

# Create the reactor database
db-create:
    psql -h localhost -p 5433 -U reactor -d postgres -c "CREATE DATABASE reactor;"

# Create the reactor_test database
db-create-test:
    psql -h localhost -p 5433 -U reactor -d postgres -c "CREATE DATABASE reactor_test;"

# Apply all pending database migrations
db-migrate:
    go run ./cmd/migrate up

# Roll back the most recent migration
db-rollback:
    go run ./cmd/migrate down

# Show migration status
db-status:
    go run ./cmd/migrate status

# Roll back all migrations
db-reset:
    go run ./cmd/migrate reset

# Show current migration version
db-version:
    go run ./cmd/migrate version
